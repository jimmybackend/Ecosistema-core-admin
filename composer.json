{
  "name": "jimmybackend/ecosistema-core-admin",
  "description": "Ecosistema Core Admin - estructura base (Capa 2)",
  "type": "project",
  "require": {
    "php": "^8.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "smoke": "php scripts/smoke-check.php",
    "cron:check": "php scripts/cron-runner.php --check",
    "cron:health": "php scripts/cron-runner.php --run=health-checks",
    "cron:sessions": "php scripts/cron-runner.php --run=session-cleanup",
    "backup:check": "php scripts/backup-check.php",
    "ops:monitor": "php scripts/ops-monitor-check.php",
    "schema:check": "php scripts/schema-compatibility-check.php",
    "schema:usage": "php scripts/schema-usage-check.php"
  }
}
